{
	"schemaVersion": 1,
	"id": "ninjabrain-fabricated",
	"version": "${version}",
	"name": "Ninjabrain-Fabricated",
	"description": "In-game stronghold calculator for Minecraft speedrunning. Port of Ninjabrain Bot using Bayesian inference.",
	"authors": [
		"Timerverse",
		"Ninjabrain (original algorithm)"
	],
	"contact": {
		"homepage": "https://github.com/Timerverse/ninjabrain-fabricated",
		"sources": "https://github.com/Timerverse/ninjabrain-fabricated"
	},
	"license": "GPL-3.0-only",
	"icon": "assets/ninjabrain-fabricated/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"org.dpdns.timerverse.ninjabrain.NinjabrainFabricated"
		],
		"client": [
			"org.dpdns.timerverse.ninjabrain.client.NinjabrainFabricatedClient"
		],
		"modmenu": [
			"org.dpdns.timerverse.ninjabrain.client.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"ninjabrain-fabricated.mixins.json",
		{
			"config": "ninjabrain-fabricated.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*",
		"cloth-config": ">=26.2"
	},
	"recommends": {
		"modmenu": ">=20.0.0"
	}
}
